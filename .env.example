# Google Drive API — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# SoundCloud API — https://soundcloud.com/you/apps
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/soundcloud/callback

# Pushover Notifications (Optional) — https://pushover.net/
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=

# Storage & Port (Optional)
PORT=3000
DATA_DIR=
